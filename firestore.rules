rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════
    //   RTX Pro Max Collections (Only)
    // ══════════════════════════════════════

    match /crypto_users/{userId} {
      allow read:  if true;
      allow write: if false;
    }

    match /crypto_payments/{txId} {
      allow create: if true;
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }

    match /crypto_trials/{userId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users - Read only
    match /crypto_users/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // Payments - Create only (no overwrite)
    match /crypto_payments/{txId} {
      allow create: if request.resource.data.txId == txId;
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Trials - Create + Update + Read
    match /crypto_trials/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}
